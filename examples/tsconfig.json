{
    "compilerOptions": {
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "lib": ["ES2022"],
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@bursora/sdk": ["../src/index.ts"]
        }
    },
    "include": ["**/*.ts", "types/**/*.d.ts"]
}
