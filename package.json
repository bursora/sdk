{
    "name": "@bursora/sdk",
    "version": "0.1.1",
    "description": "Bursora SDK: wrap your AI provider client to enforce per-customer and per-agent budgets, no proxy.",
    "license": "Apache-2.0",
    "author": "Vildan Bina <vildanbina@gmail.com>",
    "homepage": "https://bursora.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bursora/sdk.git"
    },
    "keywords": [
        "llm",
        "openai",
        "anthropic",
        "cost",
        "budget",
        "ai-agent",
        "vercel-ai-sdk"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "prepare": "husky",
        "test": "bun test",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "bun run typecheck && bun run lint && bun run format:check && bun test",
        "prepublishOnly": "bun run build"
    },
    "engines": {
        "node": ">=18",
        "bun": ">=1.0"
    },
    "peerDependencies": {
        "ai": ">=5"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        }
    },
    "devDependencies": {
        "@ai-sdk/anthropic": "^3.0.81",
        "@ai-sdk/openai": "^3.0.67",
        "@anthropic-ai/sdk": "^0.100.1",
        "@eslint/js": "^10.0.1",
        "@google/genai": "^2.7.0",
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.2",
        "ai": "^6.0.193",
        "eslint": "^10.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "msw": "2.7.0",
        "openai": "^6.39.1",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.1.0",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.1"
    }
}
