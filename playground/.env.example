# Copy to .env (gitignored) and fill in
# Bursora local dev server URL
BURSORA_ENDPOINT=http://localhost:3000

# Active API key — plaintext secret (bsk_<workspaceId>_<32hex>) from /workspace/<id>/keys
BURSORA_API_KEY=bsk_47c05e5d-af35-49a3-86a7-eaec1c86a2f1_0123456789abcdef0123456789abcdef

# Required for the anomaly mode to auto-trigger /api/cron/anomaly.
# Must match root .env CRON_SECRET exactly.
BURSORA_CRON_SECRET=
